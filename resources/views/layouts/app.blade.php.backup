<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

<script>
    // Toggle Cart Sidebar
    function toggleCart() {
        const cartSidebar = document.getElementById('cartSidebar');
        const orderSidebar = document.getElementById('orderSidebar');
        const profileSidebar = document.getElementById('profileSidebar');
        const overlay = document.getElementById('sidebarOverlay');
        
        // Close others if open
        orderSidebar.classList.remove('active');
        profileSidebar.classList.remove('active');
        
        // Toggle cart
        cartSidebar.classList.toggle('active');
        overlay.classList.toggle('active');
        
        // Prevent body scroll when sidebar is open
        if (cartSidebar.classList.contains('active')) {
            document.body.style.overflow = 'hidden';
        } else {
            document.body.style.overflow = '';
        }
    }

    // Close Cart
    function closeCart() {
        const cartSidebar = document.getElementById('cartSidebar');
        const overlay = document.getElementById('sidebarOverlay');
        
        cartSidebar.classList.remove('active');
        overlay.classList.remove('active');
        document.body.style.overflow = '';
    }

    // Toggle Orders Sidebar (NEW)
    function toggleOrders() {
        const orderSidebar = document.getElementById('orderSidebar');
        const cartSidebar = document.getElementById('cartSidebar');
        const profileSidebar = document.getElementById('profileSidebar');
        const overlay = document.getElementById('sidebarOverlay');
        
        // Close others if open
        cartSidebar.classList.remove('active');
        profileSidebar.classList.remove('active');
        
        // Toggle orders
        orderSidebar.classList.toggle('active');
        overlay.classList.toggle('active');
        
        // Prevent body scroll when sidebar is open
        if (orderSidebar.classList.contains('active')) {
            document.body.style.overflow = 'hidden';
        } else {
            document.body.style.overflow = '';
        }
    }

    // Close Orders
    function closeOrders() {
        const orderSidebar = document.getElementById('orderSidebar');
        const overlay = document.getElementById('sidebarOverlay');
        
        orderSidebar.classList.remove('active');
        overlay.classList.remove('active');
        document.body.style.overflow = '';
    }

    // Close Profile
    function closeProfile() {
        const profileSidebar = document.getElementById('profileSidebar');
        const overlay = document.getElementById('sidebarOverlay');
        
        profileSidebar.classList.remove('active');
        overlay.classList.remove('active');
        document.body.style.overflow = '';
    }

    // Toggle Profile Sidebar
    function toggleProfile() {
        const profileSidebar = document.getElementById('profileSidebar');
        const cartSidebar = document.getElementById('cartSidebar');
        const orderSidebar = document.getElementById('orderSidebar');
        const overlay = document.getElementById('sidebarOverlay');
        
        // Close others if open
        cartSidebar.classList.remove('active');
        orderSidebar.classList.remove('active');
        
        // Toggle profile
        profileSidebar.classList.toggle('active');
        overlay.classList.toggle('active');
        
        // Prevent body scroll when sidebar is open
        if (profileSidebar.classList.contains('active')) {
            document.body.style.overflow = 'hidden';
        } else {
            document.body.style.overflow = '';
        }
    }

    // Close sidebar when clicking overlay
    document.getElementById('sidebarOverlay').addEventListener('click', function() {
        closeCart();
        closeOrders();
        closeProfile();
        this.classList.remove('active');
        document.body.style.overflow = '';
    });

    // Prevent scroll on mobile when sidebar is open
    window.addEventListener('resize', function() {
        const cartSidebar = document.getElementById('cartSidebar');
        const orderSidebar = document.getElementById('orderSidebar');
        const profileSidebar = document.getElementById('profileSidebar');
        
        if (!cartSidebar.classList.contains('active') && 
            !orderSidebar.classList.contains('active') && 
            !profileSidebar.classList.contains('active')) {
            document.body.style.overflow = '';
        }
    });
</script>

</body>
</html>