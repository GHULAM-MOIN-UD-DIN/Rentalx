<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Brand - Premium Ecommerce</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    <style>
        :root {
            --primary-blue: #0d6efd;
            --gray-light: #f7f8f9;
            --text-main: #1c1c1c;
            --border-color: #e3e8ee;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body { 
            font-family: 'Inter', sans-serif; 
            background-color: #f7f8f9; 
            margin: 0;
            overflow-x: hidden;
            width: 100%;
        }

        html {
            overflow-x: hidden;
            width: 100%;
        }

        .container {
            width: 100%;
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 15px;
        }

        /* --- HEADER STYLING --- */
        header { 
            background: #fff; 
            border-bottom: 1px solid var(--border-color);
            position: sticky;
            top: 0;
            z-index: 100;
        }
        
        .header-container { 
            max-width: 1200px; 
            margin: auto; 
            padding: 15px 20px; 
        }
        
        .navbar-main { 
            display: flex; 
            align-items: center; 
            justify-content: space-between; 
            gap: 20px; 
        }
        
        .brand-section { 
            display: flex; 
            align-items: center; 
            gap: 10px; 
            text-decoration: none; 
        }
        
        .brand-logo { 
            background: var(--primary-blue); 
            color: #fff; 
            width: 40px; 
            height: 40px; 
            display: flex; 
            align-items: center; 
            justify-content: center; 
            border-radius: 8px; 
            font-size: 20px; 
        }
        
        .brand-text { 
            font-size: 24px; 
            font-weight: 800; 
            color: #1e3b5c; 
        }

        .search-bar-container { 
            flex-grow: 1; 
            display: flex; 
            max-width: 600px; 
        }
        
        .search-bar-container input { 
            width: 100%; 
            border: 2px solid var(--primary-blue); 
            border-right: none; 
            padding: 10px 15px; 
            border-radius: 8px 0 0 8px; 
            outline: none; 
        }
        
        .search-btn { 
            background: var(--primary-blue); 
            color: #fff; 
            border: none; 
            padding: 10px 25px; 
            border-radius: 0 8px 8px 0; 
            font-weight: 600;
            cursor: pointer;
        }

        .user-actions { 
            display: flex; 
            gap: 20px; 
        }
        
        .action-item { 
            text-align: center; 
            color: #8b96a5; 
            cursor: pointer; 
            text-decoration: none; 
            font-size: 13px;
            position: relative;
            transition: color 0.2s;
        }
        
        .action-item:hover {
            color: var(--primary-blue);
        }
        
        .action-item i { 
            display: block; 
            font-size: 20px; 
            margin-bottom: 3px; 
            color: #8b96a5;
            transition: color 0.2s;
        }

        .action-item:hover i {
            color: var(--primary-blue);
        }

        .cart-badge {
            position: absolute;
            top: -5px;
            right: -8px;
            background: #dc3545;
            color: white;
            border-radius: 50%;
            width: 18px;
            height: 18px;
            font-size: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 600;
        }

        .navbar-bottom { 
            border-top: 1px solid var(--border-color); 
            padding: 12px 0; 
        }
        
        .nav-flex { 
            display: flex; 
            justify-content: space-between; 
            align-items: center; 
            max-width: 1200px; 
            margin: auto; 
            padding: 0 20px; 
            font-size: 15px; 
            font-weight: 500; 
        }
        
        .nav-links-left span { 
            margin-right: 20px; 
            cursor: pointer;
            transition: color 0.2s;
        }

        .nav-links-left span:hover {
            color: var(--primary-blue);
        }
        
        .nav-links-right span { 
            margin-left: 20px;
            cursor: pointer;
        }

        /* --- SIDEBAR OVERLAY --- */
        .sidebar-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.5);
            z-index: 999;
            opacity: 0;
            visibility: hidden;
            transition: all 0.3s ease;
        }

        .sidebar-overlay.active {
            opacity: 1;
            visibility: visible;
        }

        /* --- CART SIDEBAR --- */
        .cart-sidebar {
            position: fixed;
            top: 0;
            right: -100%;
            width: 100%;
            max-width: 380px;
            height: 100%;
            background: white;
            z-index: 1000;
            transition: right 0.3s ease;
            box-shadow: -2px 0 10px rgba(0,0,0,0.1);
            display: flex;
            flex-direction: column;
            visibility: hidden;
        }

        .cart-sidebar.active {
            right: 0;
            visibility: visible;
        }

        .cart-header {
            background: var(--primary-blue);
            color: white;
            padding: 18px 20px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            border-bottom: 1px solid rgba(255,255,255,0.1);
        }

        .cart-header h3 {
            font-size: 18px;
            font-weight: 700;
            margin: 0;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .close-sidebar {
            background: none;
            border: none;
            color: white;
            font-size: 24px;
            cursor: pointer;
            padding: 0;
            width: 30px;
            height: 30px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 4px;
            transition: background 0.2s;
        }

        .close-sidebar:hover {
            background: rgba(255,255,255,0.1);
        }

        .cart-items {
            flex: 1;
            overflow-y: auto;
            padding: 0;
        }

        .cart-item {
            display: flex;
            gap: 15px;
            padding: 15px 20px;
            border-bottom: 1px solid var(--border-color);
        }

        .cart-item-image {
            width: 70px;
            height: 70px;
            background: #f5f5f5;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            flex-shrink: 0;
        }

        .cart-item-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .cart-item-image i {
            font-size: 30px;
            color: #ccc;
        }

        .cart-item-details {
            flex: 1;
        }

        .cart-item-title {
            font-size: 14px;
            font-weight: 600;
            color: var(--text-main);
            margin-bottom: 4px;
            line-height: 1.4;
        }

        .cart-item-size {
            font-size: 12px;
            color: #8b96a5;
            margin-bottom: 8px;
        }

        .cart-item-footer {
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .quantity-control {
            display: flex;
            align-items: center;
            gap: 8px;
            border: 1px solid var(--border-color);
            border-radius: 6px;
            padding: 2px;
        }

        .quantity-control form {
            display: inline;
            margin: 0;
            padding: 0;
        }

        .quantity-btn {
            background: none;
            border: none;
            width: 26px;
            height: 26px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            color: #8b96a5;
            font-size: 14px;
            border-radius: 4px;
            transition: all 0.2s;
        }

        .quantity-btn:hover:not(:disabled) {
            background: var(--gray-light);
            color: var(--primary-blue);
        }

        .quantity-btn:disabled {
            opacity: 0.4;
            cursor: not-allowed;
        }

        .quantity-value {
            font-size: 14px;
            font-weight: 600;
            min-width: 20px;
            text-align: center;
        }

        .cart-item-price {
            font-size: 16px;
            font-weight: 700;
            color: var(--text-main);
        }

        .cart-summary {
            border-top: 2px solid var(--border-color);
            padding: 20px;
            background: #fafafa;
        }

        .summary-row {
            display: flex;
            justify-content: space-between;
            margin-bottom: 12px;
            font-size: 14px;
        }

        .summary-row.total {
            font-size: 18px;
            font-weight: 700;
            color: var(--text-main);
            padding-top: 12px;
            border-top: 1px solid var(--border-color);
            margin-top: 12px;
        }

        .checkout-btn {
            width: 100%;
            background: #28a745;
            color: white;
            border: none;
            padding: 14px;
            border-radius: 8px;
            font-weight: 700;
            font-size: 15px;
            cursor: pointer;
            margin-top: 10px;
            transition: background 0.2s;
        }

        .checkout-btn:hover {
            background: #218838;
        }

        .saved-items {
            padding: 20px;
            background: white;
        }

        .saved-items h4 {
            font-size: 16px;
            font-weight: 700;
            margin-bottom: 15px;
            color: var(--text-main);
        }

        .saved-item {
            display: flex;
            gap: 12px;
            padding: 12px 0;
            border-bottom: 1px solid var(--border-color);
        }

        .saved-item:last-child {
            border-bottom: none;
        }

        .saved-item-image {
            width: 50px;
            height: 50px;
            background: #f5f5f5;
            border-radius: 6px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

        .saved-item-image i {
            font-size: 20px;
            color: #ccc;
        }

        .saved-item-details {
            flex: 1;
        }

        .saved-item-title {
            font-size: 13px;
            font-weight: 600;
            color: var(--text-main);
            margin-bottom: 4px;
        }

        .saved-item-price {
            font-size: 14px;
            font-weight: 700;
            color: var(--text-main);
        }

        .saved-item-actions {
            display: flex;
            flex-direction: column;
            gap: 4px;
        }

        .saved-action-btn {
            font-size: 11px;
            padding: 0;
            background: none;
            border: none;
            cursor: pointer;
            font-weight: 600;
        }

        .saved-action-btn.move {
            color: var(--primary-blue);
        }

        .saved-action-btn.remove {
            color: #dc3545;
        }

        /* --- ORDER SIDEBAR (NEW) --- */
        .order-sidebar {
            position: fixed;
            top: 0;
            right: -100%;
            width: 100%;
            max-width: 420px;
            height: 100%;
            background: white;
            z-index: 1000;
            transition: right 0.3s ease;
            box-shadow: -2px 0 10px rgba(0,0,0,0.1);
            display: flex;
            flex-direction: column;
            visibility: hidden;
        }

        .order-sidebar.active {
            right: 0;
            visibility: visible;
        }

        .order-header {
            background: var(--primary-blue);
            color: white;
            padding: 18px 20px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            border-bottom: 1px solid rgba(255,255,255,0.1);
        }

        .order-header h3 {
            font-size: 18px;
            font-weight: 700;
            margin: 0;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .order-list {
            flex: 1;
            overflow-y: auto;
            padding: 0;
        }

        .order-card {
            padding: 20px;
            border-bottom: 8px solid #f7f8f9;
            transition: background 0.2s;
        }

        .order-card:hover {
            background: #fafafa;
        }

        .order-card-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 12px;
        }

        .order-id {
            font-size: 13px;
            color: #8b96a5;
            font-weight: 600;
        }

        .order-status {
            padding: 4px 10px;
            border-radius: 12px;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
        }

        .order-status.pending {
            background: #fff3cd;
            color: #856404;
        }

        .order-status.completed {
            background: #d4edda;
            color: #155724;
        }

        .order-status.cancelled {
            background: #f8d7da;
            color: #721c24;
        }

        .order-date {
            font-size: 12px;
            color: #8b96a5;
            margin-bottom: 15px;
        }

        .order-items-list {
            margin-bottom: 15px;
        }

        .order-product-item {
            display: flex;
            gap: 10px;
            padding: 10px 0;
            border-bottom: 1px solid #f0f0f0;
        }

        .order-product-item:last-child {
            border-bottom: none;
        }

        .order-product-img {
            width: 50px;
            height: 50px;
            background: #f5f5f5;
            border-radius: 6px;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            flex-shrink: 0;
        }

        .order-product-img img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .order-product-img i {
            font-size: 20px;
            color: #ccc;
        }

        .order-product-info {
            flex: 1;
        }

        .order-product-name {
            font-size: 13px;
            font-weight: 600;
            color: var(--text-main);
            margin-bottom: 3px;
        }

        .order-product-qty {
            font-size: 11px;
            color: #8b96a5;
        }

        .order-product-price {
            font-size: 13px;
            font-weight: 700;
            color: var(--text-main);
            text-align: right;
        }

        .order-total {
            display: flex;
            justify-content: space-between;
            padding-top: 12px;
            border-top: 2px solid var(--border-color);
        }

        .order-total-label {
            font-size: 14px;
            font-weight: 600;
            color: #8b96a5;
        }

        .order-total-amount {
            font-size: 18px;
            font-weight: 700;
            color: var(--primary-blue);
        }

        .order-actions {
            display: flex;
            gap: 8px;
            margin-top: 15px;
        }

        .order-btn {
            flex: 1;
            padding: 8px;
            border-radius: 6px;
            font-size: 12px;
            font-weight: 600;
            text-align: center;
            cursor: pointer;
            transition: all 0.2s;
            text-decoration: none;
            border: none;
        }

        .order-btn.primary {
            background: var(--primary-blue);
            color: white;
        }

        .order-btn.primary:hover {
            background: #0b5ed7;
        }

        .order-btn.secondary {
            background: #f7f8f9;
            color: var(--text-main);
            border: 1px solid var(--border-color);
        }

        .order-btn.secondary:hover {
            background: #e9ecef;
        }

        .empty-orders {
            padding: 60px 20px;
            text-align: center;
            color: #8b96a5;
        }

        .empty-orders i {
            font-size: 48px;
            margin-bottom: 15px;
            opacity: 0.3;
        }

        /* --- PROFILE SIDEBAR --- */
        .profile-sidebar {
            position: fixed;
            top: 0;
            right: -100%;
            width: 100%;
            max-width: 320px;
            height: 100%;
            background: white;
            z-index: 1000;
            transition: right 0.3s ease;
            box-shadow: -2px 0 10px rgba(0,0,0,0.1);
            display: flex;
            flex-direction: column;
            visibility: hidden;
        }

        .profile-sidebar.active {
            right: 0;
            visibility: visible;
        }

        .profile-header {
            background: #f8f9fa;
            padding: 25px 20px;
            border-bottom: 1px solid var(--border-color);
            position: relative;
        }

        .profile-user {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 15px;
        }

        .profile-avatar {
            width: 50px;
            height: 50px;
            background: var(--gray-light);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #8b96a5;
            font-size: 24px;
            border: 2px solid var(--border-color);
        }

        .profile-info h4 {
            font-size: 16px;
            font-weight: 700;
            margin: 0;
            color: var(--text-main);
        }

        .auth-links {
            display: flex;
            gap: 10px;
        }

        .auth-link {
            flex: 1;
            text-align: center;
            padding: 8px;
            border-radius: 6px;
            text-decoration: none;
            font-size: 13px;
            font-weight: 600;
            transition: all 0.2s;
        }

        .auth-link.signin {
            background: var(--primary-blue);
            color: white;
        }

        .auth-link.signin:hover {
            background: #0b5ed7;
        }

        .auth-link.register {
            background: white;
            color: var(--primary-blue);
            border: 2px solid var(--primary-blue);
        }

        .auth-link.register:hover {
            background: rgba(13,110,253,0.1);
        }

        .profile-menu {
            flex: 1;
            overflow-y: auto;
            padding: 10px 0;
        }

        .menu-section {
            padding: 15px 0;
            border-bottom: 1px solid var(--border-color);
        }

        .menu-section:last-child {
            border-bottom: none;
        }

        .menu-item {
            display: flex;
            align-items: center;
            gap: 15px;
            padding: 12px 20px;
            color: var(--text-main);
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            transition: all 0.2s;
            cursor: pointer;
        }

        .menu-item:hover {
            background: var(--gray-light);
            color: var(--primary-blue);
        }

        .menu-item i {
            width: 20px;
            text-align: center;
            color: #8b96a5;
            font-size: 16px;
        }

        .menu-item:hover i {
            color: var(--primary-blue);
        }

        .menu-section-title {
            padding: 8px 20px;
            font-size: 12px;
            font-weight: 700;
            color: #8b96a5;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        /* --- FOOTER STYLING --- */
        .footer { 
            background: #fff; 
            padding: 40px 0 0; 
            margin-top: 50px; 
            border-top: 1px solid var(--border-color);
            width: 100%;
            overflow: hidden;
        }

        .footer .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
        }
        
        .footer-grid { 
            display: grid; 
            grid-template-columns: 2fr 1fr 1fr 1fr 1fr; 
            gap: 30px; 
            padding-bottom: 40px;
            width: 100%;
        }
        
        .blue-box-logo { 
            background: #0d6efd; 
            color: white; 
            width: 40px; 
            height: 40px; 
            display: inline-flex; 
            align-items: center; 
            justify-content: center; 
            border-radius: 8px; 
            margin-right: 10px; 
        }
        
        .footer-brand p { 
            color: #505050; 
            margin-top: 15px; 
            font-size: 14px; 
            line-height: 1.5; 
        }
        
        .social-icons a { 
            background: #bdc4cd; 
            color: white; 
            width: 32px; 
            height: 32px; 
            display: inline-flex; 
            align-items: center; 
            justify-content: center; 
            border-radius: 50%; 
            text-decoration: none; 
            margin-right: 8px; 
            transition: 0.3s; 
        }
        
        .social-icons a:hover { 
            background: var(--primary-blue); 
        }
        
        .footer-col h5 { 
            font-weight: 700; 
            margin-bottom: 20px; 
            font-size: 16px; 
        }
        
        .footer-col ul { 
            list-style: none; 
            padding: 0; 
        }
        
        .footer-col li { 
            margin-bottom: 10px; 
            color: #8b96a5; 
            font-size: 14px; 
            cursor: pointer; 
        }
        
        .footer-col li:hover { 
            color: var(--primary-blue); 
        }

        .footer-bottom { 
            background: #eee; 
            padding: 20px 0;
            width: 100%;
        }

        .footer-bottom .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
        }
        
        .bottom-content { 
            display: flex; 
            justify-content: space-between; 
            align-items: center;
            flex-wrap: wrap;
            gap: 15px;
        }
        
        .lang-select { 
            display: flex; 
            align-items: center; 
            gap: 8px; 
            font-size: 14px; 
        }

        /* Mobile Menu Toggle */
        .mobile-menu-toggle {
            display: none;
            background: none;
            border: none;
            font-size: 24px;
            color: var(--text-main);
            cursor: pointer;
        }

        /* --- RESPONSIVE DESIGN --- */
        @media (max-width: 992px) {
            .search-bar-container {
                max-width: 400px;
            }

            .nav-links-left span:not(:first-child),
            .nav-links-right span:last-child {
                display: none;
            }

            .footer-grid {
                grid-template-columns: 1fr 1fr 1fr;
                gap: 20px;
            }
        }

        @media (max-width: 768px) {
            .header-container {
                padding: 12px 15px;
            }

            .brand-text {
                font-size: 20px;
            }

            .brand-logo {
                width: 35px;
                height: 35px;
                font-size: 18px;
            }

            .search-bar-container { 
                display: none; 
            }

            .user-actions {
                gap: 12px;
            }

            .action-item span {
                display: none;
            }

            .action-item i {
                font-size: 22px;
            }

            .navbar-bottom {
                display: none;
            }

            .mobile-menu-toggle {
                display: block;
            }

            .cart-sidebar,
            .order-sidebar,
            .profile-sidebar {
                max-width: 85%;
            }

            .footer-grid { 
                grid-template-columns: 1fr 1fr;
                gap: 25px;
            }

            .footer .container {
                padding: 0 15px;
            }
        }

        @media (max-width: 576px) {
            .header-container {
                padding: 10px 12px;
            }

            .brand-text {
                font-size: 18px;
            }

            .brand-logo {
                width: 32px;
                height: 32px;
                font-size: 16px;
            }

            .user-actions {
                gap: 8px;
            }

            .action-item i {
                font-size: 20px;
            }

            .cart-sidebar,
